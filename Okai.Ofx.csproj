<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>Okai.Ofx</PackageId>
    <AssemblyName>Okai.Ofx</AssemblyName>
    <RootNamespace>Okai.Ofx</RootNamespace>
    <Version>2.0.0</Version>
    <Authors>Okai</Authors>
    <Description>A lightweight .NET library for parsing OFX bank statement transactions.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/okaidigital/Okai.Ofx</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Okai.Ofx.Tests\**\*.cs" />
    <None Remove="Okai.Ofx.Tests\**\*" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
